# ============================================
# CONFIGURACIÓN DE LA API PRINCIPAL
# ============================================
VITE_API_URL=https://quicknote-api-app-react.onrender.com/api/v1

# ============================================
# CONFIGURACIÓN DE SUPABASE (PARA EL FRONTEND)
# ============================================
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# CONFIGURACIÓN DE SUPABASE SERVICE ROLE (PARA EL SERVIDOR DE PASSKEY)
# ============================================
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN (FRONTEND)
# ============================================
VITE_APP_NAME=QuickNote
VITE_APP_VERSION=1.0.0
VITE_DOMAIN=localhost
VITE_ORIGIN=http://localhost:5173

# ============================================
# CONFIGURACIÓN DEL SERVIDOR DE PASSKEY (BACKEND)
# ============================================
PORT=3001
VITE_PASSKEY_SERVER_URL=http://localhost:3001
NODE_ENV=development

# ============================================
# CONFIGURACIÓN DE SEGURIDAD PARA EL SERVIDOR
# ============================================
JWT_SECRET=your_jwt_secret_key_here
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175